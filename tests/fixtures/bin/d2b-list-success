#!/usr/bin/env bash
set -euo pipefail

case "${1:-} ${2:-}" in
  "list --json")
    cat "${D2B_LIST_FIXTURE:-$(dirname "$0")/../d2b-list.json}"
    ;;
  "inspect alpha-vm"|"inspect sys-alpha-net")
    if [ "${D2B_ALLOW_INSPECT_FALLBACK:-0}" = "1" ]; then
      printf '{"closureOutPath":"%s"}\n' "${D2B_TEST_CLOSURE_PATH:?}"
    else
      echo "inspect fallback should not be used for list guestClosureOutPath" >&2
      exit 64
    fi
    ;;
  *)
    echo "unexpected d2b mock call: $*" >&2
    exit 64
    ;;
esac
