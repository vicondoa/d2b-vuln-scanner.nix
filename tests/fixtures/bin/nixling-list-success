#!/usr/bin/env bash
set -euo pipefail

case "${1:-} ${2:-}" in
  "list --json")
    cat "$(dirname "$0")/../nixling-list.json"
    ;;
  "inspect alpha-vm"|"inspect sys-alpha-net")
    printf '{"closureOutPath":"%s"}\n' "${D2B_TEST_CLOSURE_PATH:?}"
    ;;
  *)
    echo "unexpected nixling mock call: $*" >&2
    exit 64
    ;;
esac

