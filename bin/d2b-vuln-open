#!/usr/bin/env bash
set -euo pipefail

state_dir="${D2B_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/d2b-vuln-scanner}"
print_path=0

while [ "$#" -gt 0 ]; do
  case "$1" in
    --print-path) print_path=1; shift ;;
    --state-dir) state_dir="$2"; shift 2 ;;
    --help|-h) echo "usage: d2b-vuln-open [--print-path] [--state-dir DIR]"; exit 0 ;;
    *) echo "d2b-vuln-open: unknown argument: $1" >&2; exit 64 ;;
  esac
done

report="$state_dir/latest.txt"
if [ ! -e "$report" ]; then
  echo "d2b-vuln-open: no report found; run d2b-vuln-scan first" >&2
  exit 66
fi

if [ "$print_path" -eq 1 ]; then
  readlink -f "$report"
  exit 0
fi

if [ -n "${D2B_OPEN_ARGV_JSON:-}" ]; then
  mapfile -t argv < <(jq -r --arg report "$(readlink -f "$report")" '.[] | gsub("\\{report\\}"; $report)' <<<"$D2B_OPEN_ARGV_JSON")
  exec "${argv[@]}"
fi

if [ -t 1 ]; then
  exec less -R "$report"
fi

exec xdg-open "$report"

